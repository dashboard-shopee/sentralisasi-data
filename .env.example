# ============================================================
#  SENTRALISASI DATA — contoh konfigurasi rahasia
#  Salin file ini jadi ".env" lalu isi nilainya. JANGAN commit .env.
# ============================================================

# ---- Koneksi database Supabase (PostgreSQL) ----
# Ambil dari Supabase: Project Settings -> Database -> Connection string (URI).
# Pakai mode "Session pooler" atau "Direct connection".
DATABASE_URL=postgresql://postgres:PASSWORD@db.xxxxxxxxxxxx.supabase.co:5432/postgres

# ---- Google Service Account (untuk baca Google Sheets) ----
# Pakai service account yang SAMA yang sudah di-share Editor ke Sheet kamu
# (yang dipakai program 01 & 02). Salin nilai dari .env program tsb.
GOOGLE_PROJECT_ID=
GOOGLE_PRIVATE_KEY_ID=
GOOGLE_PRIVATE_KEY=
GOOGLE_CLIENT_EMAIL=
GOOGLE_CLIENT_ID=

# ---- ID Google Sheet sumber (sudah terisi dari program yang ada) ----
SHEET_IKLAN=1g8w73SGT6Updmehjg-z4__E_pYQ8kzS9pJ8nY-uzqgY
